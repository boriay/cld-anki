# Copy to .env.local and fill in. Vite only exposes VITE_-prefixed vars.

# Backend API base (no trailing slash). Prod: https://api.catflashcards.com
VITE_API_BASE_URL=http://localhost:8080

# Firebase Web app config — from Firebase Console > Project settings > Web app.
# Project is cld-anki-3505c (the suffixed Firebase project, not the GCP one).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=cld-anki-3505c.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=cld-anki-3505c
VITE_FIREBASE_APP_ID=
