# Copy to .env and fill in values for local development.
# Never commit .env to version control.

PORT=8080
DATABASE_URL=postgresql://postgres:password@localhost:5432/flashcard?sslmode=disable
FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to Firebase service account JSON (local dev only).
# On GKE use Workload Identity — do not set this env var.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceaccount.json
