# Copy to .env and fill in values for local development.
# Never commit .env to version control.

PORT=8080
DATABASE_URL=postgresql://postgres:password@localhost:5432/flashcard?sslmode=disable
FIREBASE_PROJECT_ID=your-firebase-project-id

# CORS allow-list for the web SPA (comma-separated). Android sends no Origin
# and is unaffected. Defaults to prod domain + Vite dev server.
CORS_ALLOWED_ORIGINS=https://catflashcards.com,http://localhost:5173

# Path to Firebase service account JSON (local dev only).
# On GKE use Workload Identity — do not set this env var.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceaccount.json

# Weather backgrounds — optional, defaults shown. GeoIP resolves the client's
# approximate location from its IP; the IP is appended as a path segment.
WEATHER_GEOIP_URL=https://ipwho.is/
WEATHER_FORECAST_URL=https://api.open-meteo.com/v1/forecast
